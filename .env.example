NAME=Name of the MCP Server
BASE_URL=http://example.com

# ROUTE_MAPS_JSON Configuration Breakdown:
# 1. {"methods": ["GET"], "mcp_type": "TOOL"} 
#    -> INCLUDES: Exposes all GET endpoints as available tools.
# 2. {"methods": ["DELETE", "PATCH"], "mcp_type": "EXCLUDE"} 
#    -> EXCLUDES: Hides all DELETE and PATCH endpoints globally to prevent destructive actions.
# 3. {"tags": ["imports"], "mcp_type": "EXCLUDE"} 
#    -> EXCLUDES: Hides all endpoints under the "imports" OpenAPI tag.
# 4. {"methods": ["POST"], "pattern": "^/example/", "mcp_type": "EXCLUDE"} 
#    -> EXCLUDES: Hides POST requests from /example/ endpoint.

ROUTE_MAPS_JSON=[{"methods": ["GET"], "mcp_type": "TOOL"}, {"methods": ["DELETE", "PATCH"], "mcp_type": "EXCLUDE"}]